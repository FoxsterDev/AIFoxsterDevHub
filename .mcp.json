{
  "$schema": "https://modelcontextprotocol.io/schema/mcp.json",
  "description": "AIFoxsterDevHub MCP configuration with xuunity-light-unity-mcp for Unity automation",
  "metadata": {
    "ai_integration_guide": "AIRoot/Operations/XUUnityLightUnityMcp/docs/agents/AI_INTEGRATION.md",
    "agent_workflows": "AIRoot/Operations/XUUnityLightUnityMcp/docs/agents/AGENT_WORKFLOWS.md",
    "unity_test_rules": ".claude/rules/unity-mcp-test-execution.md"
  },
  "mcpServers": {
    "jetbrains": {
      "type": "stdio"
    },
    "xuunity_light_unity": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-lc",
        "exec \"${CLAUDE_TOOLS_HOME:-$HOME/.claude-tools}/xuunity-light-unity-mcp/run.sh\""
      ],
      "timeout": 600000
    }
  }
}
